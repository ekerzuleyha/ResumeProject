@model ResumeProject.Entities.Portfolio
@{
    ViewData["Title"] = "UpdatePortfolio";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}
<style>
    .dark select {
        background-color: #1c2427;
        color: #ffffff;
    }

    select {
        background-color: #ffffff;
        color: #1e293b;
    }

    .dark select option {
        background-color: #1c2427;
        color: #ffffff;
    }

    select option {
        background-color: #ffffff;
        color: #1e293b;
    }
</style>
<div class="flex-1 overflow-y-auto p-8">
    <div class="max-w-7xl mx-auto space-y-8">
        <!-- Page Heading -->
        <div class="flex items-center gap-4">
            <a href="/Portfolio/PortfolioList/" class="flex items-center justify-center w-10 h-10 rounded-lg border border-slate-200 dark:border-[#3b4d54] hover:bg-slate-50 dark:hover:bg-[#1c2427] transition-colors">
                <span class="material-symbols-outlined text-[20px]">arrow_back</span>
            </a>
            <div>
                <h3 class="text-3xl font-black tracking-tight">Proje Düzenlema Sayfası</h3>
                <p class="text-slate-500 dark:text-[#9db2b9] mt-1">Proje bilgilerinizi güncelleyin.</p>
            </div>
        </div>

        <!-- Form Container -->
        <div class="bg-white dark:bg-[#111618] rounded-xl border border-slate-200 dark:border-[#3b4d54] overflow-hidden shadow-sm">
            <div class="p-8">
                <form method="post" class="space-y-6">
                    <input type="hidden" asp-for="PortfolioId">
             
                    <div>
                        <label for="Title" class="block text-sm font-bold mb-2">
                           Proje Başlığı
                            <span class="text-red-500">*</span>
                        </label>
                        <input type="text"
                               id="Title"
                               asp-for="Title"
                               class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-[#3b4d54] bg-white dark:bg-[#1c2427] focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all"
                            
                               required />
                    </div>


                    <!-- resim -->
                    <div>
                        <label for="ImageUrl" class="block text-sm font-bold mb-2">
                            Resim Url
                            <span class="text-red-500">*</span>
                        </label>
                        <input type="text"
                               name="ImageUrl"
                               class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-[#3b4d54] bg-white dark:bg-[#1c2427] focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all"
                               required />
                    </div>

                    <!-- kategori -->
                    <div>
                        <label class="block text-sm font-bold mb-2">
                            Kategori seçiniz
                            <span class="text-red-500">*</span>
                        </label>

                        @Html.DropDownListFor(x => x.CategoryId, (List<SelectListItem>)ViewBag.v, new { @class = "form-control" })
                    </div>


                    <!-- Form Actions -->
                    <div class="flex items-center gap-3 pt-4 border-t border-slate-200 dark:border-[#3b4d54]">
                        <button type="submit"
                                class="flex items-center gap-2 px-6 py-3 bg-primary text-background-dark rounded-lg font-bold text-sm hover:opacity-90 transition-opacity">
                            <span class="material-symbols-outlined text-[20px]">check</span>
                            Kaydet
                        </button>
                        <a href="/Portfolio/PortfolioList/"
                           class="flex items-center gap-2 px-6 py-3 bg-slate-100 dark:bg-[#1c2427] text-slate-700 dark:text-slate-300 rounded-lg font-bold text-sm hover:bg-slate-200 dark:hover:bg-[#283539] transition-colors">
                            <span class="material-symbols-outlined text-[20px]">close</span>
                            İptal
                        </a>
                    </div>

                </form>
            </div>
        </div>

        <!-- Info Card -->
        <div class="bg-blue-50 dark:bg-blue-950/20 border border-blue-200 dark:border-blue-900/50 rounded-xl p-6">
            <div class="flex gap-3">
                <span class="material-symbols-outlined text-blue-600 dark:text-blue-400 text-[24px]">info</span>
                <div>
                    <h4 class="font-bold text-blue-900 dark:text-blue-300 mb-1">Bilgilendirme</h4>
                    <p class="text-sm text-blue-800 dark:text-blue-400">
                        Tüm alanlar zorunludur. Hakkımda bilgilerinizi eksiksiz doldurunuz.
                    </p>
                </div>
            </div>
        </div>

    </div>
</div>


