@*  @using ResumeProject.Context
@inject ResumeDbContext _context
@using ResumeProject.Entities
@using ResumeProject.Models

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int messageCount = _context.Messages.Count();
    int projectCount = _context.Portfolios.Count();
    int notReadMessage = _context.Messages.Count(x => x.IsRead == false);
    int skillCount = _context.Skills.Count();

    ViewBag.LastMessages = _context.Messages
        .OrderByDescending(x => x.SendDate)
        .Take(5)
        .ToList();


}




<div class="p-10 space-y-10">

    <!-- STAT CARDS -->
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6">

        <!-- Projects -->
        <div class="bg-white dark:bg-[#1c2427] p-10 rounded-xl shadow flex items-center justify-between">
            <div>
                <p class="text-[25px] text-slate-500">Toplam Proje</p>

                <h3 class="text-4xl font-bold">@projectCount</h3>
            </div>
            <span class="material-symbols-outlined text-primary text-5xl">task</span>
        </div>



        <!-- Messages -->
        <div class="bg-white dark:bg-[#1c2427] p-6 rounded-xl shadow flex items-center justify-between">
            <div>
                <p class="text-[25px] text-slate-500">Toplam Mesaj</p>
                <h3 class="text-4xl font-bold">@messageCount</h3>
            </div>
            <span class="material-symbols-outlined text-primary text-5xl">mail</span>
        </div>



        <!-- Unread -->
        <div class="bg-white dark:bg-[#1c2427] p-6 rounded-xl shadow flex items-center justify-between">
            <div>
                <p class="text-[25px] text-slate-500">Okunmamış Mesaj Sayısı</p>
                <h3 class="text-4xl font-bold">@notReadMessage</h3>
            </div>
            <span class="material-symbols-outlined text-primary text-5xl">mark_email_unread</span>
        </div>


        <!-- Skills -->
        <div class="bg-white dark:bg-[#1c2427] p-6 rounded-xl shadow flex items-center justify-between">
            <div>
                <p class="text-[25px] text-slate-500">Yetenek Sayısı</p>
                <h3 class="text-4xl font-bold">@skillCount</h3>
            </div>
            <span class="material-symbols-outlined text-primary text-5xl">psychology</span>
        </div>
    </div>





    <!-- CHART + LAST MESSAGES -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

        <!-- Last Messages -->
        <div class="bg-white dark:bg-[#1c2427] p-6 rounded-xl shadow">
            <h3 class="text-lg font-semibold mb-4">Son Mesajlar</h3>
            <div class="space-y-4">
                @foreach (var item in (List<Message>)ViewBag.LastMessages)
                {
                    <div class="border-b border-slate-200 dark:border-[#283539] pb-2">
                        <p class="font-medium">@item.NameSurname</p>
                        <p class="text-sm text-slate-500 truncate">@item.MessageDetail</p>
                        <span class="text-xs text-slate-400">@item.SendDate.ToShortDateString()</span>
                    </div>
                }
            </div>
        </div>
    </div>


</div>



