@using ResumeProject.Context
@inject ResumeDbContext _context
@using ResumeProject.Entities
@using ResumeProject.Models

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int messageCount = _context.Messages.Count();
    int projectCount = _context.Portfolios.Count();
    int notReadMessage = _context.Messages.Count(x => x.IsRead == false);
    int skillCount = _context.Skills.Count();
    ViewBag.LastMessages = _context.Messages
        .OrderByDescending(x => x.SendDate)
        .Take(5)
        .ToList();
}

<div class="p-10 space-y-8">

    <h1 class="text-2xl font-semibold text-slate-700 dark:text-slate-200">Dashboard</h1>

    <!-- STAT CARDS -->
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6">

        <div class="bg-white dark:bg-[#1c2427] p-6 rounded-xl shadow flex items-center justify-between">
            <div>
                <p class="text-sm text-slate-500 mb-1">Toplam Proje</p>
                <h3 class="text-4xl font-bold text-slate-700 dark:text-white">@projectCount</h3>
            </div>
            <span class="material-symbols-outlined text-5xl text-blue-400">task</span>
        </div>

        <div class="bg-white dark:bg-[#1c2427] p-6 rounded-xl shadow flex items-center justify-between">
            <div>
                <p class="text-sm text-slate-500 mb-1">Toplam Mesaj</p>
                <h3 class="text-4xl font-bold text-slate-700 dark:text-white">@messageCount</h3>
            </div>
            <span class="material-symbols-outlined text-5xl text-indigo-400">mail</span>
        </div>

        <div class="bg-white dark:bg-[#1c2427] p-6 rounded-xl shadow flex items-center justify-between">
            <div>
                <p class="text-sm text-slate-500 mb-1">Okunmamış Mesaj</p>
                <h3 class="text-4xl font-bold text-slate-700 dark:text-white">@notReadMessage</h3>
            </div>
            <span class="material-symbols-outlined text-5xl text-rose-400">mark_email_unread</span>
        </div>

        <div class="bg-white dark:bg-[#1c2427] p-6 rounded-xl shadow flex items-center justify-between">
            <div>
                <p class="text-sm text-slate-500 mb-1">Yetenek Sayısı</p>
                <h3 class="text-4xl font-bold text-slate-700 dark:text-white">@skillCount</h3>
            </div>
            <span class="material-symbols-outlined text-5xl text-green-400">psychology</span>
        </div>

    </div>

    <!-- SON MESAJLAR -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
        <div class="bg-white dark:bg-[#1c2427] p-6 rounded-xl shadow">
            <div class="flex items-center justify-between mb-5">
                <h2 class="text-base font-semibold text-slate-700 dark:text-slate-200">Son Mesajlar</h2>
                <span class="text-xs text-blue-500 bg-blue-50 dark:bg-[#1a2f38] px-3 py-1 rounded-full">Son 5 mesaj</span>
            </div>

            @{
                var colors = new[] { "bg-blue-100 text-blue-600", "bg-green-100 text-green-600", "bg-amber-100 text-amber-600", "bg-rose-100 text-rose-600", "bg-slate-100 text-slate-600" }; int i = 0;
            }

            <div class="space-y-1">
                @foreach (var item in (List<Message>)ViewBag.LastMessages)
                {
                    var colorClass = colors[i % colors.Length];
                    i++;

                    <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-slate-50 dark:hover:bg-[#283539] transition">
                        
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center justify-between">
                                <p class="text-sm font-medium text-slate-700 dark:text-slate-200 truncate">@item.NameSurname</p>
                                <span class="text-xs text-slate-400 ml-2 flex-shrink-0">@item.SendDate.ToShortDateString()</span>
                            </div>
                            <p class="text-xs text-slate-500 truncate">@item.MessageDetail</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

</div>